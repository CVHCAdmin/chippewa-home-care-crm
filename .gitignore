# Environment secrets - NEVER commit these
.env
.env.local
.env.production
.env.staging
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Build output
frontend/dist/
frontend/build/
*.tgz

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Uploaded files (runtime data, not source)
backend/uploads/
backend/documents/

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Capacitor / Mobile builds — commit source, ignore generated artifacts
frontend/android/build/
frontend/android/.gradle/
frontend/android/app/build/
frontend/android/app/release/
frontend/android/captures/
frontend/android/local.properties
frontend/android/.idea/
frontend/android/app/release.keystore
frontend/ios/build/
frontend/ios/App/Pods/
frontend/ios/App/build/
frontend/.gradle/

# Coverage / test output
coverage/
backend/src/tests/coverage/
backend/src/server.js.bak
backend/audits/.admin_token
backend/audits/screenshots/
backend/audits/lh-*.json
backend/audits/lighthouse-*.json

# Claude Code local config — may contain machine-specific paths AND credentials
# embedded in tool-permission examples. Keep local-only.
.claude/settings.local.json
.claude/settings.json

# Cloudflare wrangler cache
.wrangler/

# Claims/renewal agent — source is tracked, but skip its installed deps
cvhc-agent/node_modules/

{
  "name": "cvhc-claims-agent",
  "version": "1.0.0",
  "description": "CVHC automated claims processing and auth renewal agents",
  "main": "agent.js",
  "scripts": {
    "claims": "node agent.js",
    "claims:dry-run": "node agent.js --dry-run",
    "claims:poll": "node agent.js --poll-only",
    "renewals": "node renewal-agent.js",
    "renewals:dry-run": "node renewal-agent.js --dry-run",
    "nightly": "node renewal-agent.js && node agent.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "16.0.3",
    "pg": "^8.11.0",
    "uuid": "^9.0.0"
  }
}
